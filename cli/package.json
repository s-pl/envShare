{
  "name": "@s-pl/envshare",
  "version": "2.0.1",
  "description": "envShare CLI — sync secrets to .env files",
  "repository": {
    "type": "git",
    "url": "https://github.com/s-pl/envShare.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "bin": {
    "envshare": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "bundle": "node build.mjs",
    "pkg:all": "pkg pkg-entry.cjs --targets node22-win-x64,node22-macos-x64,node22-macos-arm64,node22-linux-x64 --output envshare --compress GZip --no-bytecode --public",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "pkg": {
    "scripts": [
      "bundle.cjs"
    ],
    "assets": [
      "bundle.cjs"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@yao-pkg/pkg": "^5.15.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1"
  },
  "type": "module"
}

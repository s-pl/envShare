{
  "name": "envshare",
  "version": "1.0.0",
  "description": "envShare CLI — sync secrets to .env files",
  "bin": {
    "envshare": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "bundle": "node build.mjs",
    "pkg:all": "pkg pkg-entry.cjs --targets node20-win-x64,node20-macos-x64,node20-macos-arm64,node20-linux-x64 --output envshare --compress GZip --no-bytecode --public"
  },
  "pkg": {
    "scripts": [
      "bundle.cjs"
    ],
    "assets": [
      "bundle.cjs"
    ]
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "dotenv": "^16.4.5",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "react": "^18.3.1",
    "table": "^6.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/prompts": "^2.4.9",
    "@yao-pkg/pkg": "^5.15.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "type": "module"
}

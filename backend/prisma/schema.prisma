generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Environment
// Represents a single .env file at a specific path within a project.
// Examples: name="production" filePath=".env"
//           name="staging"    filePath=".env.staging"
//           name="api"        filePath="apps/api/.env"
//
// Secrets belong to an Environment, not directly to a Project.
// Every new project gets a default "production" environment automatically.
// ─────────────────────────────────────────────────────────────────────────────
model Environment {
  id          String  @id @default(cuid())
  projectId   String
  name        String // Human-readable label shown in the UI
  filePath    String // Relative path on disk (e.g. ".env", "apps/api/.env")
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secrets Secret[]

  @@unique([projectId, name])
  @@unique([projectId, filePath])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// GDPR fields: consentedAt tracks when the user accepted the Privacy Policy.
// ISO 27001 / A.9.4.2: failedLoginAttempts + lockedUntil implement account
// lockout after repeated failed authentication attempts.
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // GDPR Art. 7 — explicit consent timestamp
  consentedAt DateTime?

  // ISO 27001 A.9.4.2 — account lockout after repeated failed logins
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  projectMembers ProjectMember[]
  personalValues UserSecretValue[]
  tokens         RefreshToken[]
  secretVersions SecretVersion[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Project
// ─────────────────────────────────────────────────────────────────────────────
model Project {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  encryptedKey String // AES-256 project key encrypted with master key
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members      ProjectMember[]
  secrets      Secret[]
  environments Environment[]
}

model ProjectMember {
  id        String      @id @default(cuid())
  role      ProjectRole @default(DEVELOPER)
  projectId String
  userId    String
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

enum ProjectRole {
  ADMIN
  DEVELOPER
  VIEWER
}

// ─────────────────────────────────────────────────────────────────────────────
// Secret
// ─────────────────────────────────────────────────────────────────────────────
model Secret {
  id            String  @id @default(cuid())
  projectId     String
  environmentId String  // every secret belongs to exactly one environment

  keyHash String // HMAC-SHA256(keyName, projectKey) — dedup without revealing key name

  // Key name (encrypted, same for everyone)
  encryptedKey String
  keyIV        String
  keyTag       String

  // Shared value — visible and equal for ALL members (e.g. server URLs)
  isShared             Boolean @default(false)
  sharedEncryptedValue String?
  sharedValueIV        String?
  sharedValueTag       String?

  comment   String?
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment        @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  userValues  UserSecretValue[]
  versions    SecretVersion[]

  @@unique([projectId, keyHash, environmentId])
  @@index([projectId])
  @@index([environmentId])
  @@index([projectId, environmentId]) // composite — accelerates pull queries that filter by both
}

// Per-user personal value for a secret
model UserSecretValue {
  id             String   @id @default(cuid())
  secretId       String
  userId         String
  encryptedValue String
  valueIV        String
  valueTag       String
  updatedAt      DateTime @updatedAt

  secret Secret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([secretId, userId])
  @@index([userId])
}

// Audit trail for every change to a secret
model SecretVersion {
  id       String  @id @default(cuid())
  secretId String
  userId   String? // who made the change (null = system/migration)
  action   String  @default("updated") // "created" | "updated" | "deleted"
  isShared Boolean @default(false)

  // Snapshot of the shared value at this version (null for personal secrets)
  sharedEncryptedValue String?
  sharedValueIV        String?
  sharedValueTag       String?

  version   Int
  createdAt DateTime @default(now())

  secret Secret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([secretId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // ISO 27001 A.12.4 — track which device/client issued this token
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // used by the cleanup/retention job
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit Log
// ISO 27001 A.12.4.1 — Event Logging.
// GDPR Art. 5(1)(f) — integrity and confidentiality.
//
// ipAddress and userAgent are retained for security monitoring purposes only
// (fraud detection, anomaly alerts). They are covered under the Privacy Policy
// legitimate-interest basis and are purged after AUDIT_LOG_RETENTION_DAYS.
// ─────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  action       String
  actor        String // userId or 'system'
  resourceId   String
  resourceType String
  metadata     Json?
  createdAt    DateTime @default(now())

  // ISO 27001 A.12.4 — source context for each event
  ipAddress String?
  userAgent String?

  // Performance indexes — used by the audit query and the retention cleanup job
  @@index([actor])
  @@index([resourceType])
  @@index([resourceId])
  @@index([createdAt])
}


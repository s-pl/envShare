@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Courier
hide circle

title envShare - Entity Relationship Diagram (Conceptual)

entity User {
  * id : string
  --
  email : string
  name : string
  passwordHash : string
  consentedAt : datetime?
  failedLoginAttempts : int
  lockedUntil : datetime?
}

entity Project {
  * id : string
  --
  slug : string
  name : string
  encryptedKey : string
}

entity ProjectMember {
  * id : string
  --
  role : ADMIN|DEVELOPER|VIEWER
  projectId : string
  userId : string
}

entity Environment {
  * id : string
  --
  projectId : string
  name : string
  filePath : string
  description : string?
}

entity Secret {
  * id : string
  --
  projectId : string
  environmentId : string?
  keyHash : string
  encryptedKey : string
  isShared : boolean
  version : int
}

entity UserSecretValue {
  * id : string
  --
  secretId : string
  userId : string
  encryptedValue : string
}

entity SecretVersion {
  * id : string
  --
  secretId : string
  userId : string?
  action : string
  isShared : boolean
  version : int
}

entity RefreshToken {
  * id : string
  --
  token : string
  userId : string
  expiresAt : datetime
}

entity AuditLog {
  * id : string
  --
  actor : string
  action : string
  resourceType : string
  resourceId : string
  createdAt : datetime
}

User ||--o{ ProjectMember : membership
Project ||--o{ ProjectMember : has
Project ||--o{ Environment : contains
Project ||--o{ Secret : has
Environment ||--o{ Secret : scopes
Secret ||--o{ UserSecretValue : personal values
User ||--o{ UserSecretValue : owns
Secret ||--o{ SecretVersion : history
User ||--o{ SecretVersion : performs
User ||--o{ RefreshToken : owns

@enduml
